rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Safety net: deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email == 'tamsyra17@gmail.com';
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : {"role": "None"};
    }

    function isAdmin() {
      return isSignedIn() && (isSuperAdmin() || getUserData().role in ['Super Admin', 'Admin']);
    }

    function isManager() {
      return isSignedIn() && (isSuperAdmin() || getUserData().role in ['Super Admin', 'Admin', 'Manager']);
    }

    function isCashier() {
      return isSignedIn() && (isSuperAdmin() || getUserData().role in ['Super Admin', 'Admin', 'Manager', 'Cashier']);
    }

    function isBranchStaff(branchId) {
      return isSignedIn() && (isAdmin() || getUserData().branchId == branchId);
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Users ---
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId; 
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin()) && (
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']) || isAdmin()
      );
    }

    // --- Branches ---
    match /branches/{branchId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();

      // --- Nested Products ---
      match /products/{productId} {
        allow read: if isSignedIn() && isBranchStaff(branchId);
        allow create: if isSignedIn() && isBranchStaff(branchId) && isManager();
        allow update: if isSignedIn() && isBranchStaff(branchId) && (
          isManager() || 
          (isCashier() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stockQuantity']))
        );
        allow delete: if isAdmin();
      }

      // --- Nested Sales ---
      match /sales/{saleId} {
        allow read: if isSignedIn() && isBranchStaff(branchId);
        allow create: if isSignedIn() && isBranchStaff(branchId) && isCashier();
        allow update, delete: if isAdmin();

        match /items/{itemId} {
          allow read: if isSignedIn() && isBranchStaff(branchId);
          allow write: if isSignedIn() && isBranchStaff(branchId) && isCashier();
        }
      }

      // --- Nested Expenses ---
      match /expenses/{expenseId} {
        allow read: if isSignedIn() && isBranchStaff(branchId);
        allow create: if isSignedIn() && isBranchStaff(branchId) && isManager();
        allow update, delete: if isAdmin();
      }
    }

    // --- Global Collections ---
    match /categories/{catId} {
      allow read: if isSignedIn();
      allow write: if isManager();
    }

    match /customers/{custId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /suppliers/{suppId} {
      allow read: if isSignedIn();
      allow write: if isManager();
    }
  }
}
